{
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@types/node": "^24.0.0",
    "concurrently": "^10.0.3",
    "tsx": "^4",
    "typescript": "^5"
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "scripts": {
    "start": "cds start",
    "serve": "cds serve",
    "watch": "cds watch",
    "dev": "concurrently -n \"BE,FE\" -c \"bgBlue.bold,bgGreen.bold\" \"npm run watch\" \"npm --prefix app/training-ui run dev\""
  },
  "dependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds": "^9.9.1",
    "express": "^5.2.1"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    }
  }
}
